{
  "name": "@freshifyv2/portal-shell-ui",
  "version": "0.1.0",
  "description": "Sovereign Portal shell \u2014 Chrome, sidebar, topbar, footer, and shared CSS. Consumed by portal-shell, users-fe, companies-fe, workspaces-fe.",
  "license": "Apache-2.0",
  "author": "Freshify, Inc. (https://freshify.io)",
  "homepage": "https://github.com/freshifyv2/freshify-portal-shell-ui#readme",
  "bugs": {
    "url": "https://github.com/freshifyv2/freshify-portal-shell-ui/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freshifyv2/freshify-portal-shell-ui.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    },
    "./globals.css": "./dist/globals.css"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.cjs.json && tsc -p tsconfig.esm.json && tsc -p tsconfig.types.json && cp src/globals.css dist/globals.css",
    "prepare": "npm run build",
    "clean": "rm -rf dist node_modules"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "next": "^14.2.0",
    "react": "^18.2.0",
    "typescript": "^5.3.0"
  }
}
